# Instam Environment Variables - EXAMPLE FILE
# DO NOT COMMIT REAL PASSWORDS TO GIT
# Copy this file to .env and add your actual passwords

# MongoDB Atlas Connection
# Get from: https://cloud.mongodb.com → Database → Connect → Connect your application
VITE_MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/?appName=Cluster

# API Keys (if needed in future)
# DEEZER_API_KEY=your_deezer_api_key
# YOUTUBE_API_KEY=your_youtube_api_key
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Security Settings
VITE_ENCRYPTION_KEY=your_32_character_encryption_key_here
VITE_JWT_SECRET=your_jwt_secret_key_here
